#cobra script

#DebugInfo T

Var fillcolor vec3 255 0 0
Var boxcolor vec3 0 255 0

Image pic set cobra.png 0 0 15 15
Image player set cobra.png 0 0 1 1

Button button set cobra.png 218 218 2 2

Var px = 0
Var py = 0

Screen init 500 500
Screen caption Cobra

Loop

Screen quitControl
Screen fill fillcolor

Button button draw

Button button pressed
Break
EndPressed

Screen update 60

EndLoop



Screen fps T

Loop

Screen quitControl
Screen fill fillcolor


If control w

Var py - 1

EndIf


If control a

Var px - 1

EndIf


If control s

Var py + 1

EndIf


If control d

Var px + 1

EndIf
Image pic draw
Image player move px py
Image player draw

Screen update 60

EndLoop

